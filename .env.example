# =============================================================================
# chain — environment template
# Copy to .env and fill in values before running.
# Values marked [RAG TEAM] are provided by the rag_ingestion team after
# a successful ingestion run. Never commit .env to version control.
# =============================================================================

# --- Qdrant (provided by RAG team after ingestion) --------------------------
QDRANT_ENDPOINT=https://your-cluster.qdrant.io    # [RAG TEAM]
QDRANT_API_KEY=                                    # [RAG TEAM]
QDRANT_COLLECTION=movies                           # [RAG TEAM]
EMBEDDING_MODEL=text-embedding-3-large             # [RAG TEAM] — must match ingestion
EMBEDDING_DIMENSION=3072                           # [RAG TEAM] — must match ingestion

# --- LLM APIs ----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=sk-

# --- Chain tuning (optional — defaults shown) --------------------------------
RAG_TOP_K=8
MAX_REFINEMENTS=3
IMDB_SEARCH_LIMIT=3
CONFIDENCE_THRESHOLD=0.3
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
REASONING_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO

# --- Observability (optional) ------------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=movie-finder
