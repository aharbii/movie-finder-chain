# =============================================================================
# movie-finder-chain — Docker-only local development environment template
#
# Copy this file to `.env` before running any `make ...` target.
#
# `backend/chain/` is a library, not a standalone deployed service. These values
# are used for local development and live examples only. The test suite uses
# stubs/mocks and does not require real API keys.
#
# Never commit `.env` to version control.
# =============================================================================

# =============================================================================
# Qdrant Cloud — read-only access only
#
# Canonical contract from `movie-finder-infrastructure#9`:
#   - `QDRANT_URL`
#   - `QDRANT_API_KEY_RO`
#   - `VECTOR_COLLECTION_PREFIX` (preferred)
#   - `QDRANT_COLLECTION_PREFIX` (legacy alias)
#
# Secret storage:
#   - Azure Key Vault: `qdrant-url`, `qdrant-api-key-ro`, `qdrant-collection-prefix`
#   - Jenkins credentials: `qdrant-url`, `qdrant-api-key-ro`, `qdrant-collection-prefix`
#
# Do NOT add `QDRANT_API_KEY_RW` here. `backend/chain/` never writes to Qdrant.
#
# Note: The actual collection queried is dynamically resolved to `{PREFIX}_{MODEL}_{DIMENSION}`.
# =============================================================================
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY_RO=
VECTOR_COLLECTION_PREFIX=movies
# QDRANT_COLLECTION_PREFIX=movies
VECTOR_STORE=qdrant
VECTOR_STORE_URL=
VECTOR_STORE_API_KEY=
CHROMADB_PERSIST_PATH=outputs/chromadb/local
PINECONE_API_KEY=
PINECONE_INDEX_NAME=movie-finder-rag
PINECONE_INDEX_HOST=
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PGVECTOR_DSN=
PGVECTOR_SCHEMA=public

# =============================================================================
# Providers and Models Configuration
#
# Supported providers: anthropic, openai, groq, together, ollama, google, huggingface
# =============================================================================
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

CLASSIFIER_PROVIDER=anthropic
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

REASONING_PROVIDER=anthropic
REASONING_MODEL=claude-sonnet-4-6

# =============================================================================
# LLM APIs — required depending on the chosen providers
#
# Secret storage:
#   - Azure Key Vault: `anthropic-api-key`, `openai-api-key`, etc.
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=sk-
GROQ_API_KEY=
TOGETHER_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_URL=http://localhost:11434

# =============================================================================
# Chain tuning — optional knobs for local experimentation
# =============================================================================
RAG_TOP_K=8
MAX_REFINEMENTS=3
IMDB_SEARCH_LIMIT=3
IMDB_SEARCH_CONCURRENCY=2
IMDB_RETRY_BASE_DELAY_SECONDS=2.0
IMDB_NODE_TIMEOUT_SECONDS=10.0
CONFIDENCE_THRESHOLD=0.3
LOG_LEVEL=INFO
# text (human-readable, default) or json (structured, for Azure Monitor / log pipelines)
LOG_FORMAT=text


# =============================================================================
# Observability — LangSmith tracing (optional)
#
# Secret storage:
#   - Azure Key Vault: `langsmith-api-key`
#   - Jenkins: not used by the current chain CI slice
# =============================================================================
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=movie-finder
