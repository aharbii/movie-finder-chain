{
  // ── Python interpreter ────────────────────────────────────────────────────
  // chain/ is a uv workspace member — the venv lives at backend/.venv.
  // Run `uv sync --all-packages` from backend/ to create it.
  // If opening chain/ standalone: interpreter path walks up to backend/.venv
  "python.defaultInterpreterPath": "${workspaceFolder}/../.venv/bin/python",
  "python.terminal.activateEnvironment": true,

  // ── Ruff ──────────────────────────────────────────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "ruff.importStrategy": "fromEnvironment",

  // ── mypy ─────────────────────────────────────────────────────────────────
  "mypy-type-checker.importStrategy": "fromEnvironment",
  "mypy-type-checker.args": ["--strict"],

  // ── Editor ────────────────────────────────────────────────────────────────
  "editor.rulers": [100],
  "editor.tabSize": 4,

  // ── File explorer ─────────────────────────────────────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true
  },

  // ── Test discovery ────────────────────────────────────────────────────────
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["--asyncio-mode=auto", "-v"],
  "python.testing.unittestEnabled": false
}
