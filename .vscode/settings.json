{
  // ── Chain workspace workflow ──────────────────────────────────────────────
  // Start the dev container with `make dev`, then attach VS Code to the
  // running `chain` container. Python-powered editor features assume that
  // attached-container workflow and use the stable venv at /opt/venv.
  "python.defaultInterpreterPath": "/opt/venv/bin/python",
  "python.terminal.activateEnvironment": false,
  "python.envFile": "${workspaceFolder}/.env",

  // ── Editor intelligence ──────────────────────────────────────────────────
  "python.analysis.extraPaths": [
    "${workspaceFolder}/src",
    "${workspaceFolder}/../imdbapi/src"
  ],
  "python.analysis.autoImportCompletions": true,

  // ── Ruff ──────────────────────────────────────────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "ruff.importStrategy": "fromEnvironment",

  // ── mypy ─────────────────────────────────────────────────────────────────
  "mypy-type-checker.importStrategy": "fromEnvironment",
  "mypy-type-checker.args": ["--strict"],

  // ── Editor ────────────────────────────────────────────────────────────────
  "editor.rulers": [100],
  "editor.tabSize": 4,
  "editor.insertSpaces": true,

  // ── File explorer ─────────────────────────────────────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/htmlcov": true,
    "**/dist": true,
    "**/*.egg-info": true
  },

  // ── Test discovery ────────────────────────────────────────────────────────
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests/", "--asyncio-mode=auto", "-v"],
  "python.testing.cwd": "${workspaceFolder}",
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "python.testing.unittestEnabled": false,

  // ── Remote Development ───────────────────────────────────────────────────
  "remote.containers.copyGitConfig": true,
  "remote.containers.installExtensions": true
}
